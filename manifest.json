{
  "manifest_version": 3,
  "name": "Nanosuit Curtain",
  "description": "Cover the current page with a customizable image or a Crysis-style nanosuit hexagon curtain to kill distractions and deprioritize a window without touching its functionality.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Toggle Nanosuit Curtain"
  },
  "commands": {
    "toggle-curtain": {
      "suggested_key": {
        "default": "Alt+Shift+H",
        "windows": "Alt+Shift+H",
        "linux": "Alt+Shift+H",
        "mac": "Alt+Shift+H"
      },
      "description": "Toggle the curtain over the current page"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
